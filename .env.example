# Supabase — replace with your project values
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_publishable_key"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"

# Site URL for OAuth callbacks
VITE_SITE_URL="http://localhost:8080"

# Google OAuth — replace with your Google Cloud OAuth client ID
VITE_GOOGLE_CLIENT_ID="your_google_client_id"

# ───────────────────────────────────────────────────────────────
# Edge Function secrets — NÃO commitar valores reais.
# Defina via: supabase secrets set OPENAI_API_KEY=sk-...
# (ou no painel: Supabase → Edge Functions → Secrets)
# ───────────────────────────────────────────────────────────────

# OpenAI Moderation API — usada por moderate-image (omni-moderation-latest)
OPENAI_API_KEY="your_openai_api_key"
